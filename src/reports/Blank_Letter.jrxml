			<property name="com.jaspersoft.studio.field.label" value="stocked"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="stock"/>
		</field>
		<field name="item_total" class="java.lang.Integer">
			<property name="com.jaspersoft.studio.field.name" value="item_total"/>
			<property name="com.jaspersoft.studio.field.label" value="item_total"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="stock"/>
		</field>
	</subDataset>
	<queryString language="SQL">
		<![CDATA[SELECT `bill_id`,`gb_seller`.`name`,`value`,`paid`,`grn_date` FROM `grn` LEFT JOIN `gb_seller` ON `grn`.`goods_by` = `gb_seller`.`id` WHERE `bill_id` IN (SELECT MAX(`id`) FROM `grn`)]]>
