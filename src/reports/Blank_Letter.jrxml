	<subDataset name="Dataset1" uuid="3db90ec1-46a6-4384-9374-17463d59d660">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="JasperReports_Server\reports\communication\MySQLdatabaseadapter.jrdax"/>
		<queryString language="SQL">
			<![CDATA[SELECT `product`.`name` AS `product_name`,`brand`.`name` AS `brand_name`,`buy_price`,`stocked`,`item_total` FROM `stock` LEFT JOIN `product` ON `stock`.`product_id` = `product`.`id` LEFT JOIN `brand` ON `product`.`brand_id` = `brand`.`id` WHERE `grn_id` IN (SELECT MAX(`id`) FROM `grn`)]]>
		</queryString>
		<field name="product_name" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="name"/>
			<property name="com.jaspersoft.studio.field.label" value="product_name"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="product"/>
		</field>
		<field name="brand_name" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="name"/>
