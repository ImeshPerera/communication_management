		<queryString language="SQL">
			<![CDATA[SELECT `product`.`name` AS `product_name`,`brand`.`name` AS `brand_name`,`stock`.`buy_price`,`stock`.`sell_price`,`stock`.`stocked`,`stock`.`qty`,`gb_seller`.`name` AS `seller_name`,`grn`.`grn_date` FROM `stock` LEFT JOIN `product` ON `stock`.`product_id` = `product`.`id` LEFT JOIN `brand` ON `product`.`brand_id` = `brand`.`id` LEFT JOIN `grn` ON `stock`.grn_id = `grn`.`id` LEFT JOIN `gb_seller` ON `grn`.`goods_by` = `gb_seller`.`id`]]>
		</queryString>
