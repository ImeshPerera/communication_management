	<subDataset name="Dataset1" uuid="c9ee1132-1107-4a81-b7a5-72878f7d2edc">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="My SQL database adapter"/>
		<queryString language="SQL">
			<![CDATA[SELECT `sell_products`.`sell_price`,`sell_products`.`qty`,`sell_products`.`total`, `product`.`name` AS `product_name`, `brand`.`name` AS `brand_name` FROM `sell_products` LEFT JOIN `payment` ON `sell_products`.`payment_id` = `payment`.`id` LEFT JOIN `product` ON `sell_products`.`product_id` = `product`.`id` LEFT JOIN `brand` ON `product`.`brand_id` = `brand`.`id` WHERE `sell_products`.`payment_id` IN (SELECT MAX(`id`) FROM `payment`)]]>
		</queryString>
		<field name="sell_price" class="java.lang.Integer">
			<property name="com.jaspersoft.studio.field.name" value="sell_price"/>
			<property name="com.jaspersoft.studio.field.label" value="sell_price"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="sell_products"/>
		</field>
		<field name="qty" class="java.lang.Integer">
			<property name="com.jaspersoft.studio.field.name" value="qty"/>
			<property name="com.jaspersoft.studio.field.label" value="qty"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="sell_products"/>
		</field>
		<field name="total" class="java.lang.Integer">
			<property name="com.jaspersoft.studio.field.name" value="total"/>
			<property name="com.jaspersoft.studio.field.label" value="total"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="sell_products"/>
		</field>
		<field name="product_name" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="name"/>
			<property name="com.jaspersoft.studio.field.label" value="product_name"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="product"/>
		</field>
		<field name="brand_name" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="name"/>
			<property name="com.jaspersoft.studio.field.label" value="brand_name"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="brand"/>
		</field>
	</subDataset>
	<queryString language="SQL">
		<![CDATA[SELECT `sell_products`.`sell_price`,`sell_products`.`qty`,`sell_products`.`total`,`sell_products`.`payment_id`,`payment`.`pay_date`,`payment`.`cash`,`payment`.`total` AS `full_total`,`payment`.`balance`, `product`.`name` AS `product_name`, `brand`.`name` AS `brand_name` FROM `sell_products` LEFT JOIN `payment` ON `sell_products`.`payment_id` = `payment`.`id` LEFT JOIN `product` ON `sell_products`.`product_id` = `product`.`id` LEFT JOIN `brand` ON `product`.`brand_id` = `brand`.`id` WHERE `sell_products`.`payment_id` IN (SELECT MAX(`id`) FROM `payment`)]]>
	</queryString>
